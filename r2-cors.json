{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://complimenthotline.org",
          "https://compliment-hotline.pages.dev",
          "http://localhost:5173",
          "http://localhost:8788"
        ],
        "methods": ["GET", "PUT", "HEAD"],
        "headers": ["Content-Type", "Content-Length"]
      },
      "exposeHeaders": ["ETag"],
      "maxAgeSeconds": 3600
    }
  ]
}
